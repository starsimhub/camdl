simulate {
  from = 0 'days
  to   = 365 'days
}

scenarios {
  no_sia {
    label = "no SIA (baseline)"
    set = {
      beta      = 0.30
      gamma     = 0.12
      vacc_frac = 0.8
    }
  }

  target_10 {
    label = "SIA in 10 lowest-coverage patches"
    set = { vacc_frac = 0.8 }
    enable = [sia_p0, sia_p1, sia_p2, sia_p3, sia_p4, sia_p5, sia_p6, sia_p7, sia_p8, sia_p9]
  }

  sia_all {
    label = "SIA in all 50 patches"
    set = { vacc_frac = 0.8 }
    enable = [sia_p0, sia_p1, sia_p2, sia_p3, sia_p4, sia_p5, sia_p6, sia_p7, sia_p8, sia_p9,
              sia_p10, sia_p11, sia_p12, sia_p13, sia_p14, sia_p15, sia_p16, sia_p17, sia_p18, sia_p19,
              sia_p20, sia_p21, sia_p22, sia_p23, sia_p24, sia_p25, sia_p26, sia_p27, sia_p28, sia_p29,
              sia_p30, sia_p31, sia_p32, sia_p33, sia_p34, sia_p35, sia_p36, sia_p37, sia_p38, sia_p39,
              sia_p40, sia_p41, sia_p42, sia_p43, sia_p44, sia_p45, sia_p46, sia_p47, sia_p48, sia_p49]
  }
}
