{
  "name": "seir_age",
  "version": "0.3",
  "description": "Age-stratified SEIR with two age groups (child/adult) and a 2x2 contact matrix.",
  "compartments": [
    { "name": "S_child", "kind": "integer" },
    { "name": "E_child", "kind": "integer" },
    { "name": "I_child", "kind": "integer" },
    { "name": "R_child", "kind": "integer" },
    { "name": "S_adult", "kind": "integer" },
    { "name": "E_adult", "kind": "integer" },
    { "name": "I_adult", "kind": "integer" },
    { "name": "R_adult", "kind": "integer" }
  ],
  "transitions": [
    {
      "name": "infection_child",
      "stoichiometry": [["S_child", -1], ["E_child", 1]],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": {
            "bin_op": {
              "op": "mul",
              "left": { "param": "beta" },
              "right": { "pop": "S_child" }
            }
          },
          "right": {
            "bin_op": {
              "op": "add",
              "left": {
                "bin_op": {
                  "op": "mul",
                  "left": { "table_lookup": { "table": "C_age", "indices": [{ "const": 0.0 }, { "const": 0.0 }] } },
                  "right": {
                    "bin_op": {
                      "op": "div",
                      "left": { "pop": "I_child" },
                      "right": { "pop_sum": ["S_child", "E_child", "I_child", "R_child"] }
                    }
                  }
                }
              },
              "right": {
                "bin_op": {
                  "op": "mul",
                  "left": { "table_lookup": { "table": "C_age", "indices": [{ "const": 0.0 }, { "const": 1.0 }] } },
                  "right": {
                    "bin_op": {
                      "op": "div",
                      "left": { "pop": "I_adult" },
                      "right": { "pop_sum": ["S_adult", "E_adult", "I_adult", "R_adult"] }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "event_key": "infection_child:{firing_index}",
      "metadata": { "origin_kind": "transmission", "source_compartment": "S_child", "dest_compartment": "E_child" }
    },
    {
      "name": "infection_adult",
      "stoichiometry": [["S_adult", -1], ["E_adult", 1]],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": {
            "bin_op": {
              "op": "mul",
              "left": { "param": "beta" },
              "right": { "pop": "S_adult" }
            }
          },
          "right": {
            "bin_op": {
              "op": "add",
              "left": {
                "bin_op": {
                  "op": "mul",
                  "left": { "table_lookup": { "table": "C_age", "indices": [{ "const": 1.0 }, { "const": 0.0 }] } },
                  "right": {
                    "bin_op": {
                      "op": "div",
                      "left": { "pop": "I_child" },
                      "right": { "pop_sum": ["S_child", "E_child", "I_child", "R_child"] }
                    }
                  }
                }
              },
              "right": {
                "bin_op": {
                  "op": "mul",
                  "left": { "table_lookup": { "table": "C_age", "indices": [{ "const": 1.0 }, { "const": 1.0 }] } },
                  "right": {
                    "bin_op": {
                      "op": "div",
                      "left": { "pop": "I_adult" },
                      "right": { "pop_sum": ["S_adult", "E_adult", "I_adult", "R_adult"] }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "event_key": "infection_adult:{firing_index}",
      "metadata": { "origin_kind": "transmission", "source_compartment": "S_adult", "dest_compartment": "E_adult" }
    },
    {
      "name": "progression_child",
      "stoichiometry": [["E_child", -1], ["I_child", 1]],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": { "param": "sigma" },
          "right": { "pop": "E_child" }
        }
      },
      "event_key": "progression_child:{firing_index}",
      "metadata": { "origin_kind": "intrinsic", "source_compartment": "E_child", "dest_compartment": "I_child" }
    },
    {
      "name": "progression_adult",
      "stoichiometry": [["E_adult", -1], ["I_adult", 1]],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": { "param": "sigma" },
          "right": { "pop": "E_adult" }
        }
      },
      "event_key": "progression_adult:{firing_index}",
      "metadata": { "origin_kind": "intrinsic", "source_compartment": "E_adult", "dest_compartment": "I_adult" }
    },
    {
      "name": "recovery_child",
      "stoichiometry": [["I_child", -1], ["R_child", 1]],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": { "param": "gamma" },
          "right": { "pop": "I_child" }
        }
      },
      "event_key": "recovery_child:{firing_index}",
      "metadata": { "origin_kind": "intrinsic", "source_compartment": "I_child", "dest_compartment": "R_child" }
    },
    {
      "name": "recovery_adult",
      "stoichiometry": [["I_adult", -1], ["R_adult", 1]],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": { "param": "gamma" },
          "right": { "pop": "I_adult" }
        }
      },
      "event_key": "recovery_adult:{firing_index}",
      "metadata": { "origin_kind": "intrinsic", "source_compartment": "I_adult", "dest_compartment": "R_adult" }
    }
  ],
  "ode_equations": [],
  "time_functions": [],
  "tables": [
    {
      "name": "C_age",
      "shape": [2, 2],
      "values": [12.0, 4.0, 4.0, 8.0],
      "out_of_bounds": "error"
    }
  ],
  "interventions": [],
  "observations": [
    {
      "name": "cases_child",
      "data_stream": "cases_child",
      "schedule": { "regular": { "start": 7.0, "step": 7.0, "end": 365.0 } },
      "projection": { "cumulative_flow": "infection_child" },
      "likelihood": {
        "neg_binomial": {
          "mean": { "projected": null },
          "dispersion": { "param": "rho" }
        }
      }
    },
    {
      "name": "cases_adult",
      "data_stream": "cases_adult",
      "schedule": { "regular": { "start": 7.0, "step": 7.0, "end": 365.0 } },
      "projection": { "cumulative_flow": "infection_adult" },
      "likelihood": {
        "neg_binomial": {
          "mean": { "projected": null },
          "dispersion": { "param": "rho" }
        }
      }
    }
  ],
  "parameters": [
    { "name": "beta", "value": 0.3, "prior": null, "transform": null, "initial_value": null },
    { "name": "sigma", "value": 0.2, "prior": null, "transform": null, "initial_value": null },
    { "name": "gamma", "value": 0.1, "prior": null, "transform": null, "initial_value": null },
    { "name": "rho", "value": 10.0, "prior": null, "transform": null, "initial_value": null }
  ],
  "initial_conditions": {
    "explicit": {
      "S_child": 49990,
      "E_child": 0,
      "I_child": 10,
      "R_child": 0,
      "S_adult": 50000,
      "E_adult": 0,
      "I_adult": 0,
      "R_adult": 0
    }
  },
  "data_contract": null,
  "output": {
    "times": { "regular": { "start": 0.0, "step": 7.0, "end": 365.0 } },
    "format": "tsv",
    "trajectory": true,
    "observations": true
  },
  "simulation": {
    "t_start": 0.0,
    "t_end": 365.0,
    "time_semantics": "continuous",
    "dt": null,
    "rng_seed": 42
  }
}
