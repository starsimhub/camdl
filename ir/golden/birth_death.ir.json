{
  "name": "birth_death",
  "version": "0.3",
  "description": "Linear birth-death process: ∅ → X at lambda*X, X → ∅ at mu*X. Poisson steady state when lambda < mu.",
  "compartments": [
    {"name": "X", "kind": "integer"}
  ],
  "transitions": [
    {
      "name": "birth",
      "stoichiometry": [["X", 1]],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": {"param": "lambda"},
          "right": {"pop": "X"}
        }
      },
      "event_key": "birth:{firing_index}",
      "metadata": {"origin_kind": "inflow", "source_compartment": null, "dest_compartment": "X"}
    },
    {
      "name": "death",
      "stoichiometry": [["X", -1]],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": {"param": "mu"},
          "right": {"pop": "X"}
        }
      },
      "event_key": "death:{firing_index}",
      "metadata": {"origin_kind": "outflow", "source_compartment": "X", "dest_compartment": null}
    }
  ],
  "ode_equations": [],
  "time_functions": [],
  "tables": [],
  "interventions": [],
  "observations": [
    {
      "name": "count",
      "data_stream": "X_obs",
      "schedule": {"regular": {"start": 1.0, "step": 1.0, "end": 50.0}},
      "projection": {"current_pop": "X"},
      "likelihood": {
        "poisson": {"rate": {"projected": null}}
      }
    }
  ],
  "parameters": [
    {"name": "lambda", "value": 0.10, "prior": null, "transform": null, "initial_value": null},
    {"name": "mu",     "value": 0.15, "prior": null, "transform": null, "initial_value": null}
  ],
  "initial_conditions": {
    "explicit": {"X": 100}
  },
  "data_contract": null,
  "output": {
    "times": {"regular": {"start": 0.0, "step": 1.0, "end": 50.0}},
    "format": "tsv",
    "trajectory": true,
    "observations": true
  },
  "simulation": {
    "t_start": 0.0,
    "t_end": 50.0,
    "time_semantics": "continuous",
    "dt": null,
    "rng_seed": 42
  }
}
