{
  "name": "sir_demography",
  "version": "0.3",
  "description": "SIR with births into S and deaths from all compartments (open population)",
  "compartments": [
    {
      "name": "S",
      "kind": "integer"
    },
    {
      "name": "I",
      "kind": "integer"
    },
    {
      "name": "R",
      "kind": "integer"
    }
  ],
  "transitions": [
    {
      "name": "infection",
      "stoichiometry": [
        [
          "S",
          -1
        ],
        [
          "I",
          1
        ]
      ],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": {
            "bin_op": {
              "op": "mul",
              "left": {
                "param": "beta"
              },
              "right": {
                "pop": "S"
              }
            }
          },
          "right": {
            "bin_op": {
              "op": "div",
              "left": {
                "pop": "I"
              },
              "right": {
                "pop_sum": [
                  "S",
                  "I",
                  "R"
                ]
              }
            }
          }
        }
      },
      "event_key": "infection:{firing_index}",
      "metadata": {
        "origin_kind": "transmission",
        "source_compartment": "S",
        "dest_compartment": "I"
      }
    },
    {
      "name": "recovery",
      "stoichiometry": [
        [
          "I",
          -1
        ],
        [
          "R",
          1
        ]
      ],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": {
            "param": "gamma"
          },
          "right": {
            "pop": "I"
          }
        }
      },
      "event_key": "recovery:{firing_index}",
      "metadata": {
        "origin_kind": "intrinsic",
        "source_compartment": "I",
        "dest_compartment": "R"
      }
    },
    {
      "name": "birth",
      "stoichiometry": [
        [
          "S",
          1
        ]
      ],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": {
            "param": "mu"
          },
          "right": {
            "pop_sum": [
              "S",
              "I",
              "R"
            ]
          }
        }
      },
      "event_key": "birth:{firing_index}",
      "metadata": {
        "origin_kind": "inflow",
        "source_compartment": null,
        "dest_compartment": "S"
      }
    },
    {
      "name": "death_S",
      "stoichiometry": [
        [
          "S",
          -1
        ]
      ],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": {
            "param": "mu"
          },
          "right": {
            "pop": "S"
          }
        }
      },
      "event_key": "death_S:{firing_index}",
      "metadata": {
        "origin_kind": "outflow",
        "source_compartment": "S",
        "dest_compartment": null
      }
    },
    {
      "name": "death_I",
      "stoichiometry": [
        [
          "I",
          -1
        ]
      ],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": {
            "param": "mu"
          },
          "right": {
            "pop": "I"
          }
        }
      },
      "event_key": "death_I:{firing_index}",
      "metadata": {
        "origin_kind": "outflow",
        "source_compartment": "I",
        "dest_compartment": null
      }
    },
    {
      "name": "death_R",
      "stoichiometry": [
        [
          "R",
          -1
        ]
      ],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": {
            "param": "mu"
          },
          "right": {
            "pop": "R"
          }
        }
      },
      "event_key": "death_R:{firing_index}",
      "metadata": {
        "origin_kind": "outflow",
        "source_compartment": "R",
        "dest_compartment": null
      }
    }
  ],
  "ode_equations": [],
  "time_functions": [],
  "tables": [],
  "interventions": [],
  "observations": [
    {
      "name": "reported_cases",
      "data_stream": "cases",
      "schedule": {
        "regular": {
          "start": 7.0,
          "step": 7.0,
          "end": 365.0
        }
      },
      "projection": {
        "cumulative_flow": "infection"
      },
      "likelihood": {
        "poisson": {
          "rate": {
            "projected": null
          }
        }
      }
    }
  ],
  "parameters": [
    {
      "name": "beta",
      "value": 0.3,
      "prior": null,
      "transform": null,
      "initial_value": null
    },
    {
      "name": "gamma",
      "value": 0.1,
      "prior": null,
      "transform": null,
      "initial_value": null
    },
    {
      "name": "mu",
      "value": 4.6e-05,
      "prior": null,
      "transform": null,
      "initial_value": null
    }
  ],
  "initial_conditions": {
    "explicit": {
      "S": 9990,
      "I": 10,
      "R": 0
    }
  },
  "data_contract": null,
  "output": {
    "times": {
      "regular": {
        "start": 0.0,
        "step": 7.0,
        "end": 365.0
      }
    },
    "format": "tsv",
    "trajectory": true,
    "observations": true
  },
  "simulation": {
    "t_start": 0.0,
    "t_end": 365.0,
    "time_semantics": "continuous",
    "dt": null,
    "rng_seed": 42
  }
}
