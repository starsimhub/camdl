{
  "name": "seir_erlang",
  "version": "0.3",
  "description": null,
  "compartments": [
    { "name": "S", "kind": "integer" },
    { "name": "E_e1", "kind": "integer" },
    { "name": "E_e2", "kind": "integer" },
    { "name": "E_e3", "kind": "integer" },
    { "name": "I", "kind": "integer" },
    { "name": "R", "kind": "integer" }
  ],
  "transitions": [
    {
      "name": "infection",
      "stoichiometry": [ [ "S", -1 ], [ "E_e1", 1 ] ],
      "rate": {
        "bin_op": {
          "op": "div",
          "left": {
            "bin_op": {
              "op": "mul",
              "left": {
                "bin_op": {
                  "op": "mul",
                  "left": { "param": "beta" },
                  "right": { "pop": "S" }
                }
              },
              "right": { "pop": "I" }
            }
          },
          "right": { "pop_sum": [ "S", "E_e1", "E_e2", "E_e3", "I", "R" ] }
        }
      },
      "event_key": "infection:{firing_index}",
      "metadata": {
        "origin_kind": "transmission",
        "source_compartment": "S",
        "dest_compartment": "E_e1"
      }
    },
    {
      "name": "latent_e1",
      "stoichiometry": [ [ "E_e1", -1 ], [ "E_e2", 1 ] ],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": {
            "bin_op": {
              "op": "mul",
              "left": { "const": 3.0 },
              "right": { "param": "sigma" }
            }
          },
          "right": { "pop": "E_e1" }
        }
      },
      "event_key": "latent_e1:{firing_index}",
      "metadata": {
        "origin_kind": "intrinsic",
        "source_compartment": "E_e1",
        "dest_compartment": "E_e2"
      }
    },
    {
      "name": "latent_e2",
      "stoichiometry": [ [ "E_e2", -1 ], [ "E_e3", 1 ] ],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": {
            "bin_op": {
              "op": "mul",
              "left": { "const": 3.0 },
              "right": { "param": "sigma" }
            }
          },
          "right": { "pop": "E_e2" }
        }
      },
      "event_key": "latent_e2:{firing_index}",
      "metadata": {
        "origin_kind": "intrinsic",
        "source_compartment": "E_e2",
        "dest_compartment": "E_e3"
      }
    },
    {
      "name": "onset",
      "stoichiometry": [ [ "E_e3", -1 ], [ "I", 1 ] ],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": {
            "bin_op": {
              "op": "mul",
              "left": { "const": 3.0 },
              "right": { "param": "sigma" }
            }
          },
          "right": { "pop": "E_e3" }
        }
      },
      "event_key": "onset:{firing_index}",
      "metadata": {
        "origin_kind": "intrinsic",
        "source_compartment": "E_e3",
        "dest_compartment": "I"
      }
    },
    {
      "name": "recovery",
      "stoichiometry": [ [ "I", -1 ], [ "R", 1 ] ],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": { "param": "gamma" },
          "right": { "pop": "I" }
        }
      },
      "event_key": "recovery:{firing_index}",
      "metadata": {
        "origin_kind": "intrinsic",
        "source_compartment": "I",
        "dest_compartment": "R"
      }
    }
  ],
  "ode_equations": [],
  "time_functions": [],
  "tables": [],
  "interventions": [],
  "observations": [],
  "parameters": [
    {
      "name": "beta",
      "value": null,
      "bounds": [ 0.001, 2.0 ],
      "prior": null,
      "transform": null,
      "initial_value": null
    },
    {
      "name": "sigma",
      "value": null,
      "bounds": [ 0.01, 1.0 ],
      "prior": null,
      "transform": null,
      "initial_value": null
    },
    {
      "name": "gamma",
      "value": null,
      "bounds": [ 0.01, 1.0 ],
      "prior": null,
      "transform": null,
      "initial_value": null
    }
  ],
  "initial_conditions": { "explicit": { "S": 990.0, "E_e1": 5.0, "I": 5.0 } },
  "data_contract": null,
  "output": {
    "times": { "regular": { "start": 0.0, "step": 1.0, "end": 365.0 } },
    "format": "tsv",
    "trajectory": true,
    "observations": true
  },
  "simulation": {
    "t_start": 0.0,
    "t_end": 365.0,
    "time_semantics": "continuous",
    "dt": null,
    "rng_seed": null
  },
  "presets": [
    {
      "name": "baseline",
      "label": "default  (latent ≈ 5d)",
      "params": { "beta": 0.3, "sigma": 0.2, "gamma": 0.1 },
      "t_end": 180.0
    },
    {
      "name": "slow_progression",
      "label": "slow progression  (latent ≈ 10d)",
      "params": { "beta": 0.3, "sigma": 0.1, "gamma": 0.1 },
      "t_end": 250.0
    }
  ]
}
