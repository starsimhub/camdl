# Bare SIR: 3 compartments, 2 transitions (§23.1)
time_unit = 'days

compartments { S, I, R }

let N = S + I + R

parameters {
  beta  : rate     in [0.001, 2.0]
  gamma : rate     in [0.001, 1.0]
  N0    : count    in [100, 100000]
  I0    : count    in [1, 1000]
}

transitions {
  infection : S --> I  @ beta * S * (I / N)
  recovery  : I --> R  @ gamma * I
}

init {
  S = N0 - I0
  I = I0
}

simulate {
  from = 0 'days
  to   = 80 'days
}

scenarios {
  baseline {
    label = "default  (R0 ≈ 3)"
    simulate { to = 80 'days }
    set = {
      beta  = 0.3
      gamma = 0.1
      N0    = 1000
      I0    = 10
    }
  }
  high_r0 {
    label = "high R0  (R0 = 5)"
    simulate { to = 80 'days }
    set = {
      beta  = 0.5
      gamma = 0.1
      N0    = 1000
      I0    = 5
    }
  }
}
