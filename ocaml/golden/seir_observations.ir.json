                  "op": "mul",
                  "left": { "param": "beta" },
                  "right": { "pop": "S" }
                }
              },
              "right": { "pop": "I" }
            }
          },
          "right": { "pop_sum": [ "S", "E", "I", "R" ] }
        }
      },
      "metadata": {
        "origin_kind": "transmission",
        "source_compartment": "S",
        "dest_compartment": "E"
      },
      "rate_grad": {
