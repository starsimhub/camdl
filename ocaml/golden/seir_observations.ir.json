                    "op": "mul",
                    "left": { "pop": "S" },
                    "right": { "pop": "I" }
                  }
                },
                "right": { "pop_sum": [ "S", "E", "I", "R" ] }
              }
            },
            "right": {
              "bin_op": {
                "op": "mul",
                "left": { "pop_sum": [ "S", "E", "I", "R" ] },
                "right": { "pop_sum": [ "S", "E", "I", "R" ] }
              }
            }
          }
        }
      }
    },
    {
      "name": "progression",
      "stoichiometry": [ [ "E", -1 ], [ "I", 1 ] ],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": { "param": "sigma" },
          "right": { "pop": "E" }
        }
      },
      "metadata": {
        "origin_kind": "intrinsic",
        "source_compartment": "E",
        "dest_compartment": "I"
      },
      "rate_grad": { "sigma": { "pop": "E" } }
    },
    {
      "name": "recovery",
      "stoichiometry": [ [ "I", -1 ], [ "R", 1 ] ],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": { "param": "gamma" },
          "right": { "pop": "I" }
        }
      },
      "metadata": {
        "origin_kind": "intrinsic",
        "source_compartment": "I",
        "dest_compartment": "R"
      },
      "rate_grad": { "gamma": { "pop": "I" } }
    }
  ],
