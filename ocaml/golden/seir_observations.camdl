# SEIR with observations block
# Demonstrates neg_binomial and bernoulli observation models.
# Weekly case counts (NegBinomial) and binary detection signal (Bernoulli).

time_unit = 'days

compartments { S, E, I, R }

let N = S + E + I + R

parameters {
  beta       : rate        in [0.001, 0.5]
  sigma      : rate        in [0.01,  1.0]
  gamma      : rate        in [0.01,  1.0]
  rho        : probability in [0.0,   1.0]   # reporting fraction
  k          : real        in [0.1,  100.0]  # NB dispersion
  p_detect   : probability in [0.0,   1.0]   # binary detection prob
  N0         : count       in [1000, 1000000]
  I0         : count       in [1,    10000]
}

transitions {
  infection   : S --> E  @ beta * S * I / N
  progression : E --> I  @ sigma * E
  recovery    : I --> R  @ gamma * I
}

observations {
  weekly_cases : {
    projected  = incidence(infection)
    every      = 7 'days
    likelihood = neg_binomial(mean = rho * projected, r = k)
  }

  detection : {
    projected  = prevalence(I)
    every      = 14 'days
    likelihood = bernoulli(p = p_detect)
  }
}

init {
  S = N0 - I0
  I = I0
}

simulate {
  from = 0 'days
  to   = 1 'years
}

scenarios {
  baseline {
    set = {
      beta      = 0.3
      sigma     = 0.2
      gamma     = 0.1
      rho       = 0.5
      k         = 5.0
      p_detect  = 0.8
      N0        = 100000
      I0        = 10
    }
  }
}
