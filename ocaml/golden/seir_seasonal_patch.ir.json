{
  "name": "seir_seasonal_patch",
  "version": "0.3",
  "time_unit": "days",
  "description": null,
  "compartments": [
    { "name": "S_urban", "kind": "integer" },
    { "name": "S_rural", "kind": "integer" },
    { "name": "E_urban", "kind": "integer" },
    { "name": "E_rural", "kind": "integer" },
    { "name": "I_urban", "kind": "integer" },
    { "name": "I_rural", "kind": "integer" },
    { "name": "R_urban", "kind": "integer" },
    { "name": "R_rural", "kind": "integer" }
  ],
  "transitions": [
    {
      "name": "infection_urban",
      "stoichiometry": [ [ "S_urban", -1 ], [ "E_urban", 1 ] ],
      "rate": {
        "bin_op": {
          "op": "div",
          "left": {
            "bin_op": {
              "op": "mul",
              "left": {
                "bin_op": {
                  "op": "mul",
                  "left": { "time_func": { "name": "seasonal_urban" } },
                  "right": { "pop": "S_urban" }
                }
              },
              "right": { "pop": "I_urban" }
            }
          },
          "right": {
            "pop_sum": [ "S_urban", "E_urban", "I_urban", "R_urban" ]
          }
        }
      },
      "event_key": "infection_urban:{firing_index}",
      "metadata": {
        "origin_kind": "transmission",
        "source_compartment": "S_urban",
        "dest_compartment": "E_urban"
      }
    },
    {
      "name": "infection_rural",
      "stoichiometry": [ [ "S_rural", -1 ], [ "E_rural", 1 ] ],
      "rate": {
        "bin_op": {
          "op": "div",
          "left": {
            "bin_op": {
              "op": "mul",
              "left": {
                "bin_op": {
                  "op": "mul",
                  "left": { "time_func": { "name": "seasonal_rural" } },
                  "right": { "pop": "S_rural" }
                }
              },
              "right": { "pop": "I_rural" }
            }
          },
          "right": {
            "pop_sum": [ "S_rural", "E_rural", "I_rural", "R_rural" ]
          }
        }
      },
      "event_key": "infection_rural:{firing_index}",
      "metadata": {
        "origin_kind": "transmission",
        "source_compartment": "S_rural",
        "dest_compartment": "E_rural"
      }
    },
    {
      "name": "progression_urban",
      "stoichiometry": [ [ "E_urban", -1 ], [ "I_urban", 1 ] ],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": { "param": "sigma" },
          "right": { "pop": "E_urban" }
        }
      },
      "event_key": "progression_urban:{firing_index}",
      "metadata": {
        "origin_kind": "intrinsic",
        "source_compartment": "E_urban",
        "dest_compartment": "I_urban"
      }
    },
    {
      "name": "progression_rural",
      "stoichiometry": [ [ "E_rural", -1 ], [ "I_rural", 1 ] ],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": { "param": "sigma" },
          "right": { "pop": "E_rural" }
        }
      },
      "event_key": "progression_rural:{firing_index}",
      "metadata": {
        "origin_kind": "intrinsic",
        "source_compartment": "E_rural",
        "dest_compartment": "I_rural"
      }
    },
    {
      "name": "recovery_urban",
      "stoichiometry": [ [ "I_urban", -1 ], [ "R_urban", 1 ] ],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": { "param": "gamma" },
          "right": { "pop": "I_urban" }
        }
      },
      "event_key": "recovery_urban:{firing_index}",
      "metadata": {
        "origin_kind": "intrinsic",
        "source_compartment": "I_urban",
        "dest_compartment": "R_urban"
      }
    },
    {
      "name": "recovery_rural",
      "stoichiometry": [ [ "I_rural", -1 ], [ "R_rural", 1 ] ],
      "rate": {
        "bin_op": {
          "op": "mul",
          "left": { "param": "gamma" },
          "right": { "pop": "I_rural" }
        }
      },
      "event_key": "recovery_rural:{firing_index}",
      "metadata": {
        "origin_kind": "intrinsic",
        "source_compartment": "I_rural",
        "dest_compartment": "R_rural"
      }
    }
  ],
  "ode_equations": [],
  "time_functions": [
    {
      "name": "seasonal_urban",
      "kind": {
        "sinusoidal": {
          "amplitude": { "param": "amp_urban" },
          "period": { "const": 365.0 },
          "phase": { "const": 0.0 },
          "baseline": { "param": "baseline" }
        }
      }
    },
    {
      "name": "seasonal_rural",
      "kind": {
        "sinusoidal": {
          "amplitude": { "param": "amp_rural" },
          "period": { "const": 365.0 },
          "phase": { "const": 0.0 },
          "baseline": { "param": "baseline" }
        }
      }
    }
  ],
  "tables": [],
  "interventions": [],
  "observations": [],
  "parameters": [
    {
      "name": "sigma",
      "value": null,
      "bounds": [ 0.01, 1.0 ],
      "prior": null,
      "transform": null,
      "initial_value": null,
      "param_kind": "rate"
    },
    {
      "name": "gamma",
      "value": null,
      "bounds": [ 0.01, 1.0 ],
      "prior": null,
      "transform": null,
      "initial_value": null,
      "param_kind": "rate"
    },
    {
      "name": "baseline",
      "value": null,
      "bounds": [ 0.01, 1.0 ],
      "prior": null,
      "transform": null,
      "initial_value": null,
      "param_kind": "rate"
    },
    {
      "name": "amp_urban",
      "value": null,
      "bounds": [ 0.0, 1.0 ],
      "prior": null,
      "transform": null,
      "initial_value": null,
      "param_kind": "positive"
    },
    {
      "name": "amp_rural",
      "value": null,
      "bounds": [ 0.0, 1.0 ],
      "prior": null,
      "transform": null,
      "initial_value": null,
      "param_kind": "positive"
    },
    {
      "name": "N0_urban",
      "value": null,
      "bounds": [ 100.0, 1000000.0 ],
      "prior": null,
      "transform": null,
      "initial_value": null,
      "param_kind": "count"
    },
    {
      "name": "N0_rural",
      "value": null,
      "bounds": [ 100.0, 1000000.0 ],
      "prior": null,
      "transform": null,
      "initial_value": null,
      "param_kind": "count"
    },
    {
      "name": "I0",
      "value": null,
      "bounds": [ 1.0, 1000.0 ],
      "prior": null,
      "transform": null,
      "initial_value": null,
      "param_kind": "count"
    }
  ],
  "parameter_groups": [],
  "initial_conditions": {
    "parameterized": {
      "S_urban": {
        "bin_op": {
          "op": "sub",
          "left": { "param": "N0_urban" },
          "right": { "param": "I0" }
        }
      },
      "I_urban": { "param": "I0" },
      "S_rural": { "param": "N0_rural" }
    }
  },
  "data_contract": null,
  "output": {
    "times": { "regular": { "start": 0.0, "step": 1.0, "end": 365.0 } },
    "format": "tsv",
    "trajectory": true,
    "observations": true
  },
  "simulation": {
    "t_start": 0.0,
    "t_end": 365.0,
    "time_semantics": "continuous",
    "dt": null,
    "rng_seed": null
  },
  "scenarios": [
    {
      "name": "baseline_scenario",
      "label": "baseline",
      "params": {
        "sigma": 0.2,
        "gamma": 0.1,
        "baseline": 0.3,
        "amp_urban": 0.4,
        "amp_rural": 0.2,
        "N0_urban": 100000.0,
        "N0_rural": 50000.0,
        "I0": 10.0
      },
      "enable": [],
      "disable": [],
      "t_end": null
    }
  ],
  "model_structure": {
    "dimensions": [ { "name": "patch", "values": [ "urban", "rural" ] } ],
    "compartment_dims": {
      "S": [ "patch" ],
      "E": [ "patch" ],
      "I": [ "patch" ],
      "R": [ "patch" ]
    },
    "base_compartments": [ "S", "E", "I", "R" ],
    "transmission_transitions": [ "infection" ],
    "infectious_compartments": [ "I" ]
  }
}
