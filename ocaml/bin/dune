(executable
 (name camdlc)
 (libraries compiler ir))

; Generate version.ml with the git hash at build time.
; (universe) ensures it's regenerated on every build; dune's content-based
; caching suppresses OCaml recompilation when the hash hasn't changed.
(rule
 (target version.ml)
 (deps (universe))
 (action
  (with-stdout-to %{target}
   (bash "hash=$(git rev-parse --short HEAD 2>/dev/null || echo unknown); printf 'let git_hash = \"%s\"\\n' \"$hash\""))))
